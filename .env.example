# LLM configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
REPORT_LLM_PROVIDER=openai
REPORT_LLM_MODEL=gpt-4o
WRITER_LLM_PROVIDER=openai
WRITER_LLM_MODEL=gpt-4o
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
LANGSMITH_ENABLED=true
LANGSMITH_PROJECT=battery-strategy-agent
LANGSMITH_API_KEY=YOUR_LANGSMITH_API_KEY
QUIET_THIRD_PARTY_LOGS=true
# Optional: set a Hugging Face token to reduce rate limits during first-time model downloads
# HF_TOKEN=hf_xxx

# Retrieval configuration
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
VECTOR_STORE=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma
LOCAL_RAG_PREWARM_ENABLED=true
LOCAL_CORPUS_PAGE_LIMIT=100
WEB_SEARCH_PROVIDER=google_news
GOOGLE_NEWS_PERIOD=24m
GOOGLE_NEWS_LANGUAGES=ko,en
GOOGLE_NEWS_MAX_RESULTS_PER_QUERY=3
ARTICLE_FETCH_MAX_DOCUMENTS=6
ARTICLE_FETCH_TIMEOUT_SECONDS=8
ARTICLE_FETCH_MAX_RETRIES=1
ARTICLE_FETCH_CHAR_LIMIT=4000

# Retry configuration
DOCUMENT_SEARCH_MAX_RETRIES=2
WEB_SEARCH_MAX_RETRIES=1
RETRIEVAL_REFINEMENT_MAX_ROUNDS=1
RETRIEVAL_REFINEMENT_MAX_QUERIES_PER_BUCKET=2
REPORT_MAX_REVISIONS=2
